# ─────────────────────────────────────────────────────────────
# WebFetch API — credentials and config
# Lives in project root. Already in .gitignore — never commit this.
# config.py loads it via python-dotenv. No other module reads .env directly.
# ─────────────────────────────────────────────────────────────

# Exa search — REQUIRED for search() to work at all.
# Get a key at https://dashboard.exa.ai  (free tier covers this project)
EXA_API_KEY=

# Anthropic — OPTIONAL. Only used by the Haiku summarizer.
# Leave blank and the pipeline still works; summary fields just return null.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# MySQL — the webfetch DB is created by the work order's CREATE DATABASE step,
# but DB_USER must already exist with rights on it. Use a dedicated user, not root.
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=webfetch

# Chrome remote-debugging session (for auth/JS-heavy fetches via your own login).
# Start Chrome with this BEFORE running the server (see below).
CHROME_CDP_URL=http://localhost:9222
CHROME_DATA_DIR=G:\chrome-bank\selenium.driver.python
